{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd marcas/feria-effix/assets/landing-ecuador && npm install && npm run build && cp dist/index-v3.html dist/index.html",
  "outputDirectory": "marcas/feria-effix/assets/landing-ecuador/dist",
  "installCommand": "echo skip-root-install",
  "framework": null,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/gracias", "destination": "/thank-you.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)\\.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
